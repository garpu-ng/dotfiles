#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias grep='grep --color=auto'

# Katakana hostname for prompt display (system hostname stays ASCII)
HOSTNAME_PRETTY="$(hostnamectl --pretty 2>/dev/null)"
HOSTNAME_PRETTY="${HOSTNAME_PRETTY:-\h}"
PS1='[\u@'"$HOSTNAME_PRETTY"' \W] 喝\$ '
export PATH="$HOME/.local/bin:$PATH"

# Run fastfetch on Ghostty startup
if [ "$TERM_PROGRAM" = "ghostty" ] && [ -z "$FASTFETCH_SHOWN" ]; then
    export FASTFETCH_SHOWN=1
    command -v fastfetch >/dev/null && { fastfetch; echo; }
fi
